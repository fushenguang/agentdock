{
  "rules": [
    {
      "id": "@secretlint/secretlint-rule-preset-recommend",
      "rules": [
        {
          "id": "@secretlint/secretlint-rule-aws",
          "options": {
            "allows": [
              "/YOUR[_-]?KEY[_-]?HERE/i",
              "/YOUR[_-]?ACCESS[_-]?KEY/i",
              "/YOUR[_-]?SECRET/i",
              "/REPLACE[_-]?ME/i",
              "/PLACEHOLDER/i"
            ]
          }
        },
        {
          "id": "@secretlint/secretlint-rule-github",
          "options": {
            "allows": [
              "/YOUR[_-]?KEY[_-]?HERE/i",
              "/YOUR[_-]?TOKEN/i",
              "/your-token/i",
              "/REPLACE[_-]?ME/i"
            ]
          }
        },
        {
          "id": "@secretlint/secretlint-rule-gcp",
          "options": {
            "allows": [
              "/YOUR[_-]?KEY[_-]?HERE/i",
              "/YOUR[_-]?API[_-]?KEY/i",
              "/REPLACE[_-]?ME/i"
            ]
          }
        }
      ]
    }
  ]
}
