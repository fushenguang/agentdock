# secretlint ignore patterns
# Files that generate many false positives or are not user-authored code

# Package manager lockfiles contain hashes that can look like secrets
pnpm-lock.yaml
package-lock.json
yarn.lock

# Binary / compiled output
dist/
.next/
.turbo/
node_modules/

# Generated source maps
**/*.map

# Test fixture directories
**/__fixtures__/

# Editor and OS artifacts
.DS_Store
*.log

# Example files with placeholder private keys (not real secrets)
templates/web-nextjs/apps/web/.env.example
templates/web-nextjs/apps/docs/content/docs/template/alipay.mdx
templates/web-nextjs/apps/docs/content/docs/template/wechat-pay.mdx
openspec/changes/**/specs/**/*.md
